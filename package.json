    "@tiptap/starter-kit": "^3.22.3",
    "@types/react-grid-layout": "^2.1.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-grid-layout": "^2.2.3",
